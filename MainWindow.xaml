<Window x:Class="InventoryPlus.MainWindow"
    x:Name="MainInventoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Inventory+"
        Width="900" Height="580"
        MinWidth="700" MinHeight="440"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BackgroundBrush}"
        FontFamily="Segoe UI">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="56"/>   <!-- Header -->
            <RowDefinition Height="*"/>    <!-- Content -->
        </Grid.RowDefinitions>

        <!-- ── Header ─────────────────────────────────────────────────────── -->
        <Border Grid.Row="0"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,0,1">
            <Grid Margin="20,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- App title -->
                <TextBlock Grid.Column="0"
                           Text="Inventory+"
                           FontSize="18"
                           FontFamily="Segoe UI Semibold"
                           Foreground="{StaticResource AccentBrush}"
                           VerticalAlignment="Center"/>

                <!-- Search area: SearchBox drives live filtering in MainWindow.xaml.cs -->
                <Border Grid.Column="1"
                        Margin="24,0"
                        Background="{StaticResource BackgroundBrush}"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="4"
                        CornerRadius="6"
                        VerticalAlignment="Center"
                        MaxWidth="340">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   Text="&#x1F50D;"
                                   FontSize="13"
                                   Margin="10,0,4,0"
                                   VerticalAlignment="Center"
                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                        <!-- TextBox ID: SearchBox -->
                        <TextBox  Grid.Column="1"
                                  x:Name="SearchBox"
                                  BorderThickness="0"
                                  Background="Transparent"
                                  Padding="4,8"
                                  FontSize="13"
                                  Foreground="{StaticResource TextPrimaryBrush}"
                                  VerticalAlignment="Center"
                                  TextChanged="SearchBox_TextChanged"/>
                    </Grid>
                </Border>

                <!-- Action buttons -->
                <StackPanel Grid.Column="2"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">

                    <!-- Stock stepper — adjusts the selected item's quantity -->
                    <Border x:Name="StockStepper"
                            Height="34"
                            Margin="0,0,12,0"
                            VerticalAlignment="Center"
                            Background="{StaticResource SurfaceBrush}"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="6">
                        <StackPanel Orientation="Horizontal">
                            <Button x:Name="DecreaseBtn"
                                    Style="{StaticResource StepperButton}"
                                    Content="&#x2212;"
                                    IsEnabled="False"
                                    ToolTip="Remove from the selected item's stock"
                                    Click="DecreaseStock_Click"/>
                            <Border Width="1" Background="{StaticResource BorderBrush}"/>
                            <!-- TextBox ID: StockAmountBox (amount used by +/- stock buttons) -->
                            <TextBox x:Name="StockAmountBox"
                                     Text="1"
                                     Width="44"
                                     MaxLength="4"
                                     BorderThickness="0"
                                     Background="Transparent"
                                     FontSize="13"
                                     TextAlignment="Center"
                                     VerticalContentAlignment="Center"
                                     Foreground="{StaticResource TextPrimaryBrush}"
                                     ToolTip="Amount to add or remove (1–9999)"
                                     PreviewTextInput="StockAmountBox_PreviewTextInput"/>
                            <Border Width="1" Background="{StaticResource BorderBrush}"/>
                            <Button x:Name="IncreaseBtn"
                                    Style="{StaticResource StepperButton}"
                                    Content="+"
                                    IsEnabled="False"
                                    ToolTip="Add to the selected item's stock"
                                    Click="IncreaseStock_Click"/>
                        </StackPanel>
                    </Border>

                        <!-- Button ID: AddItemButton -->
                        <Button x:Name="AddItemButton"
                            Style="{StaticResource AccentButton}"
                            Content="+ Add Item"
                            Click="AddItem_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ── Content ────────────────────────────────────────────────────── -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>           <!-- List -->
                <ColumnDefinition Width="Auto"/>        <!-- Splitter -->
                <ColumnDefinition Width="260" MinWidth="200"/> <!-- Detail -->
            </Grid.ColumnDefinitions>

            <!-- Item List -->
            <Grid Grid.Column="0" Margin="16,12,8,16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Column headers -->
                <Border Grid.Row="0"
                        Background="{StaticResource BackgroundBrush}"
                        CornerRadius="6,6,0,0"
                        Padding="12,8">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="90"/>
                            <ColumnDefinition Width="110"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Name"     Style="{StaticResource FieldLabel}" Margin="0"/>
                        <TextBlock Grid.Column="1" Text="Qty"      Style="{StaticResource FieldLabel}" Margin="0" TextAlignment="Center"/>
                        <TextBlock Grid.Column="2" Text="Category" Style="{StaticResource FieldLabel}" Margin="0"/>
                    </Grid>
                </Border>

                <!-- List -->
                <ListView Grid.Row="1"
                          x:Name="ItemList"
                          Background="{StaticResource SurfaceBrush}"
                          BorderBrush="{StaticResource BorderBrush}"
                          BorderThickness="1"
                          ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                          SelectionChanged="ItemList_SelectionChanged">
                    <ListView.Resources>
                        <Style TargetType="ListViewItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="Padding" Value="12,9"/>
                            <Setter Property="BorderThickness" Value="0,0,0,1"/>
                            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
                            <Setter Property="Cursor" Value="Hand"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListViewItem">
                                        <Border x:Name="Bd"
                                                Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                Padding="{TemplateBinding Padding}">
                                            <ContentPresenter/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource RowHoverBrush}"/>
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="#D6E4FD"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListView.Resources>
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="90"/>
                                    <ColumnDefinition Width="110"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           Text="{Binding Name}"
                                           FontSize="13"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           TextTrimming="CharacterEllipsis"
                                           VerticalAlignment="Center"/>
                                <Border Grid.Column="1"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Background="{StaticResource RowHoverBrush}"
                                        CornerRadius="4"
                                        Padding="8,2">
                                    <TextBlock Text="{Binding Quantity}"
                                               FontSize="12"
                                               FontFamily="Segoe UI Semibold"
                                               Foreground="{StaticResource AccentBrush}"
                                               TextAlignment="Center"/>
                                </Border>
                                <TextBlock Grid.Column="2"
                                           Text="{Binding Category}"
                                           FontSize="12"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           TextTrimming="CharacterEllipsis"
                                           VerticalAlignment="Center"/>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>

            <!-- Splitter -->
            <GridSplitter Grid.Column="1"
                          Width="4"
                          VerticalAlignment="Stretch"
                          HorizontalAlignment="Center"
                          Background="{StaticResource BorderBrush}"
                          ResizeBehavior="PreviousAndNext"/>

            <!-- Detail Panel -->
            <Border Grid.Column="2"
                    Margin="8,12,16,16"
                    Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8">

                <Grid x:Name="DetailPanel">
                    <!-- Empty state -->
                    <StackPanel x:Name="EmptyDetail"
                                VerticalAlignment="Center"
                                HorizontalAlignment="Center">
                        <TextBlock Text="📦"
                                   FontSize="40"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="Select an item"
                                   FontSize="13"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   HorizontalAlignment="Center"
                                   Margin="0,8,0,0"/>
                    </StackPanel>

                    <!-- Item detail -->
                    <StackPanel x:Name="ItemDetail"
                                Visibility="Collapsed"
                                Margin="16">

                        <!-- Image -->
                        <Border CornerRadius="8"
                                Width="180" Height="180"
                                HorizontalAlignment="Center"
                                Background="{StaticResource BackgroundBrush}"
                                ClipToBounds="True"
                                Margin="0,4,0,14">
                            <Image x:Name="DetailImage"
                                   Stretch="UniformToFill"/>
                        </Border>

                        <!-- Name -->
                        <TextBlock x:Name="DetailName"
                                   FontFamily="Segoe UI Semibold"
                                   FontSize="15"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   TextWrapping="Wrap"
                                   HorizontalAlignment="Center"
                                   TextAlignment="Center"/>

                        <!-- Category pill -->
                        <Border HorizontalAlignment="Center"
                                Margin="0,6,0,0"
                                Background="{StaticResource RowHoverBrush}"
                                CornerRadius="10"
                                Padding="10,3">
                            <TextBlock x:Name="DetailCategory"
                                       FontSize="11"
                                       Foreground="{StaticResource AccentBrush}"/>
                        </Border>

                        <!-- Quantity -->
                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Center"
                                    Margin="0,12,0,0">
                            <TextBlock Text="Qty: "
                                       FontSize="13"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       VerticalAlignment="Center"/>
                            <TextBlock x:Name="DetailQty"
                                       FontFamily="Segoe UI Semibold"
                                       FontSize="13"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>

                        <!-- Description -->
                        <TextBlock x:Name="DetailDesc"
                                   FontSize="12"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   TextWrapping="Wrap"
                                   Margin="0,10,0,0"
                                   MaxHeight="80"
                                   TextTrimming="CharacterEllipsis"/>

                        <!-- Buttons -->
                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Center"
                                    Margin="0,16,0,0">
                                <!-- Button ID: EditItemButton -->
                                <Button x:Name="EditItemButton"
                                    Style="{StaticResource GhostButton}"
                                    Content="Edit"
                                    Margin="0,0,8,0"
                                    Click="EditItem_Click"/>
                                <!-- Button ID: DeleteItemButton -->
                                <Button x:Name="DeleteItemButton"
                                    Style="{StaticResource DangerButton}"
                                    Content="Delete"
                                    Click="DeleteItem_Click"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
