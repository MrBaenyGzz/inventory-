<Window x:Class="InventoryPlus.AddEditWindow"
    x:Name="AddEditItemWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Item"
        Width="420" Height="570"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BackgroundBrush}"
        FontFamily="Segoe UI">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- Title -->
            <RowDefinition Height="*"/>     <!-- Form -->
            <RowDefinition Height="Auto"/>  <!-- Buttons -->
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Grid.Row="0"
                   x:Name="DialogTitle"
                   Text="New Item"
                   FontFamily="Segoe UI Semibold"
                   FontSize="17"
                   Foreground="{StaticResource TextPrimaryBrush}"
                   Margin="0,0,0,20"/>

        <!-- Form: scrollable with mouse wheel + right-side scrollbar -->
        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      CanContentScroll="False"
                      PanningMode="VerticalOnly">
            <StackPanel>

            <!-- Image picker -->
            <StackPanel Margin="0,0,0,14">
                <TextBlock Text="Image (optional)" Style="{StaticResource FieldLabel}"/>
                <Border x:Name="ImageBorder"
                        Width="110" Height="110"
                        HorizontalAlignment="Left"
                        Background="{StaticResource SurfaceBrush}"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="3"
                        CornerRadius="8"
                        ClipToBounds="True"
                        Cursor="Hand"
                        MouseLeftButtonUp="PickImage_Click">
                    <Grid>
                        <Image x:Name="PreviewImage" Stretch="UniformToFill"/>
                        <TextBlock x:Name="ImagePlaceholder"
                                   Text="+ Add Photo"
                                   FontSize="12"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Grid>
                </Border>
            </StackPanel>

            <!-- Name input (required) - TextBox ID: NameBox -->
            <StackPanel Margin="0,0,0,14">
                <TextBlock Text="Name *" Style="{StaticResource FieldLabel}"/>
                <TextBox x:Name="NameBox" Style="{StaticResource ModernTextBox}"/>
            </StackPanel>

            <!-- Bought price input (required) - TextBox ID: BoughtPriceBox -->
            <StackPanel Margin="0,0,0,14">
                <TextBlock Text="Bought Price *" Style="{StaticResource FieldLabel}"/>
                <TextBox x:Name="BoughtPriceBox"
                         Style="{StaticResource ModernTextBox}"
                         Text="0"
                         PreviewTextInput="PriceBox_PreviewTextInput"/>
            </StackPanel>

            <!-- Selling price input (required) - TextBox ID: SellingPriceBox -->
            <StackPanel Margin="0,0,0,14">
                <TextBlock Text="Selling Price *" Style="{StaticResource FieldLabel}"/>
                <TextBox x:Name="SellingPriceBox"
                         Style="{StaticResource ModernTextBox}"
                         Text="0"
                         PreviewTextInput="PriceBox_PreviewTextInput"/>
            </StackPanel>

            <!-- Quantity input (required) - TextBox ID: QtyBox -->
            <StackPanel Margin="0,0,0,14">
                <TextBlock Text="Quantity *" Style="{StaticResource FieldLabel}"/>
                <TextBox x:Name="QtyBox"
                         Style="{StaticResource ModernTextBox}"
                         Text="1"
                         PreviewTextInput="QtyBox_PreviewTextInput"/>
            </StackPanel>

            <!-- Category input (optional) - TextBox ID: CategoryBox -->
            <StackPanel Margin="0,0,0,14">
                <TextBlock Text="Category" Style="{StaticResource FieldLabel}"/>
                <TextBox x:Name="CategoryBox" Style="{StaticResource ModernTextBox}"/>
            </StackPanel>

            <!-- Description input (optional, multiline) - TextBox ID: DescBox -->
            <StackPanel>
                <TextBlock Text="Description" Style="{StaticResource FieldLabel}"/>
                <TextBox x:Name="DescBox"
                         Style="{StaticResource ModernTextBox}"
                         Height="68"
                         TextWrapping="Wrap"
                         AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto"/>
            </StackPanel>
            </StackPanel>
        </ScrollViewer>

        <!-- Footer Buttons -->
        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,20,0,0">
                <!-- Button ID: CancelButton -->
                <Button x:Name="CancelButton"
                    Style="{StaticResource GhostButton}"
                    Content="Cancel"
                    Margin="0,0,10,0"
                    IsCancel="True"
                    Click="Cancel_Click"/>
                <!-- Button ID: SaveButton -->
                <Button x:Name="SaveButton"
                    Style="{StaticResource AccentButton}"
                    Content="Save"
                    IsDefault="True"
                    Click="Save_Click"/>
        </StackPanel>
    </Grid>
</Window>
