<Window x:Class="InventoryPlus.AddEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Item"
        Width="420" Height="620"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BackgroundBrush}"
        FontFamily="Segoe UI">

    <Window.Resources>
        <!-- Thin, modern scrollbar (applies to scrollbars inside this window) -->
        <Style TargetType="ScrollBar">
            <Setter Property="Width" Value="8"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Background="Transparent">
                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageUpCommand"
                                                  Opacity="0" Focusable="False"/>
                                </Track.DecreaseRepeatButton>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageDownCommand"
                                                  Opacity="0" Focusable="False"/>
                                </Track.IncreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border Background="#C7CBD1"
                                                        CornerRadius="4"
                                                        Margin="2,0"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- Title -->
            <RowDefinition Height="*"/>     <!-- Form -->
            <RowDefinition Height="Auto"/>  <!-- Buttons -->
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Grid.Row="0"
                   x:Name="DialogTitle"
                   Text="New Item"
                   FontFamily="Segoe UI Semibold"
                   FontSize="17"
                   Foreground="{StaticResource TextPrimaryBrush}"
                   Margin="0,0,0,20"/>

        <!-- Form (scrollable as a safety net so content never gets clipped) -->
        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      Padding="0,0,4,0">
        <StackPanel>

            <!-- Image picker -->
            <StackPanel Margin="0,0,0,14">
                <TextBlock Text="Image (optional)" Style="{StaticResource FieldLabel}"/>
                <Border x:Name="ImageBorder"
                        Width="110" Height="110"
                        HorizontalAlignment="Left"
                        Background="{StaticResource SurfaceBrush}"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        ClipToBounds="True"
                        Cursor="Hand"
                        MouseLeftButtonUp="PickImage_Click">
                    <Grid>
                        <Image x:Name="PreviewImage" Stretch="UniformToFill"/>
                        <TextBlock x:Name="ImagePlaceholder"
                                   Text="+ Add Photo"
                                   FontSize="12"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Grid>
                </Border>
            </StackPanel>

            <!-- Name -->
            <StackPanel Margin="0,0,0,14">
                <TextBlock Text="Name *" Style="{StaticResource FieldLabel}"/>
                <TextBox x:Name="NameBox" Style="{StaticResource ModernTextBox}"/>
            </StackPanel>

            <!-- Quantity -->
            <StackPanel Margin="0,0,0,14">
                <TextBlock Text="Quantity *" Style="{StaticResource FieldLabel}"/>
                <TextBox x:Name="QtyBox"
                         Style="{StaticResource ModernTextBox}"
                         Text="1"
                         PreviewTextInput="QtyBox_PreviewTextInput"/>
            </StackPanel>

            <!-- Category -->
            <StackPanel Margin="0,0,0,14">
                <TextBlock Text="Category" Style="{StaticResource FieldLabel}"/>
                <TextBox x:Name="CategoryBox" Style="{StaticResource ModernTextBox}"/>
            </StackPanel>

            <!-- Description -->
            <StackPanel Margin="0,0,0,16">
                <TextBlock Text="Description" Style="{StaticResource FieldLabel}"/>
                <TextBox x:Name="DescBox"
                         Style="{StaticResource ModernTextBox}"
                         Height="68"
                         TextWrapping="Wrap"
                         AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto"/>
            </StackPanel>
        </StackPanel>
        </ScrollViewer>

        <!-- Footer Buttons -->
        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,20,0,0">
            <Button Style="{StaticResource GhostButton}"
                    Content="Cancel"
                    Margin="0,0,10,0"
                    IsCancel="True"
                    Click="Cancel_Click"/>
            <Button Style="{StaticResource AccentButton}"
                    Content="Save"
                    IsDefault="True"
                    Click="Save_Click"/>
        </StackPanel>
    </Grid>
</Window>
